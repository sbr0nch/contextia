[
  {
    "id": "mailchimp_key",
    "label": "Mailchimp API key",
    "severity": "critical",
    "pattern": "\\b[0-9a-f]{32}-us\\d{1,2}\\b",
    "positives": ["{a:32}-us1", "{f:32}-us20"],
    "negatives": ["abcd-us1", "{a:32}-usX", "not a mailchimp key"]
  },
  {
    "id": "mailgun_key",
    "label": "Mailgun API key",
    "severity": "critical",
    "pattern": "\\bkey-[0-9a-zA-Z]{32}\\b",
    "positives": ["key-{a:32}", "key-{A:32}"],
    "negatives": ["key-tooshort", "a keyword here", "key-{a:31}"]
  },
  {
    "id": "newrelic_key",
    "label": "New Relic user key",
    "severity": "critical",
    "pattern": "\\bNRAK-[A-Z0-9]{27}\\b",
    "positives": ["NRAK-{A:27}", "NRAK-{0:27}"],
    "negatives": ["NRAK-short", "nrak-{A:27}", "just some text"]
  },
  {
    "id": "pypi_token",
    "label": "PyPI upload token",
    "severity": "critical",
    "pattern": "\\bpypi-AgEI[A-Za-z0-9_-]{50,}\\b",
    "positives": ["pypi-AgEI{a:50}", "pypi-AgEI{A:60}"],
    "negatives": ["pypi-short", "pypi-XXXX{a:50}", "a pypi package"]
  },
  {
    "id": "doppler_token",
    "label": "Doppler personal token",
    "severity": "critical",
    "pattern": "\\bdp\\.pt\\.[A-Za-z0-9]{43}\\b",
    "positives": ["dp.pt.{a:43}", "dp.pt.{A:43}"],
    "negatives": ["dp.pt.short", "dp.sa.{a:43}", "doppler config"]
  },
  {
    "id": "grafana_token",
    "label": "Grafana service account token",
    "severity": "critical",
    "pattern": "\\bglsa_[A-Za-z0-9]{32}_[a-f0-9]{8}\\b",
    "positives": ["glsa_{a:32}_{0:8}", "glsa_{A:32}_{f:8}"],
    "negatives": ["glsa_short", "glsa_{a:32}_xyz", "grafana dashboard"]
  },
  {
    "id": "databricks_token",
    "label": "Databricks token",
    "severity": "critical",
    "pattern": "\\bdapi[0-9a-f]{32}\\b",
    "positives": ["dapi{a:32}", "dapi{0:32}"],
    "negatives": ["dapishort", "dapi{g:32}", "a databricks notebook"]
  },
  {
    "id": "telegram_bot_token",
    "label": "Telegram bot token",
    "severity": "critical",
    "pattern": "\\b\\d{8,10}:[A-Za-z0-9_-]{35}\\b",
    "positives": ["{1:9}:{a:35}", "{0:10}:{A:35}"],
    "negatives": ["123:abc", "{1:9}:{a:34}", "a telegram message"]
  },
  {
    "id": "brevo_key",
    "label": "Brevo (Sendinblue) API key",
    "severity": "critical",
    "pattern": "\\bxkeysib-[a-f0-9]{64}-[A-Za-z0-9]{16}\\b",
    "positives": ["xkeysib-{a:64}-{A:16}", "xkeysib-{0:64}-{b:16}"],
    "negatives": ["xkeysib-short", "xkeysib-{a:64}-short", "a brevo email"]
  },
  {
    "id": "planetscale_token",
    "label": "PlanetScale password token",
    "severity": "critical",
    "pattern": "\\bpscale_tkn_[A-Za-z0-9_-]{32,}\\b",
    "positives": ["pscale_tkn_{a:32}", "pscale_tkn_{A:40}"],
    "negatives": ["pscale_tkn_short", "pscale_pw_{a:32}", "a planetscale db"]
  },
  {
    "id": "openrouter_key",
    "label": "OpenRouter API key",
    "severity": "critical",
    "pattern": "\\bsk-or-v1-[0-9a-f]{40,}\\b",
    "positives": ["sk-or-v1-{a:40}", "sk-or-v1-{0:50}"],
    "negatives": ["sk-or-v1-short", "sk-or-v2-{a:40}", "an openrouter model"]
  },
  {
    "id": "groq_key",
    "label": "Groq API key",
    "severity": "critical",
    "pattern": "\\bgsk_[A-Za-z0-9]{52}\\b",
    "positives": ["gsk_{a:52}", "gsk_{A:52}"],
    "negatives": ["gsk_short", "gsk_{a:51}", "a groq request"]
  },
  {
    "id": "perplexity_key",
    "label": "Perplexity API key",
    "severity": "critical",
    "pattern": "\\bpplx-[A-Za-z0-9]{40,}\\b",
    "positives": ["pplx-{a:48}", "pplx-{A:40}"],
    "negatives": ["pplx-short", "pplx-{a:39}", "a perplexity search"]
  },
  {
    "id": "replicate_token",
    "label": "Replicate API token",
    "severity": "critical",
    "pattern": "\\br8_[A-Za-z0-9]{37}\\b",
    "positives": ["r8_{a:37}", "r8_{A:37}"],
    "negatives": ["r8_short", "r8_{a:36}", "a replicate model"]
  },
  {
    "id": "notion_token",
    "label": "Notion integration token",
    "severity": "critical",
    "pattern": "\\bntn_[0-9A-Za-z]{40,}\\b",
    "positives": ["ntn_{a:46}", "ntn_{A:40}"],
    "negatives": ["ntn_short", "ntn_{a:39}", "a notion page"]
  },
  {
    "id": "discord_bot_token",
    "label": "Discord bot token",
    "severity": "critical",
    "pattern": "\\b[MNO][A-Za-z0-9_-]{23,25}\\.[A-Za-z0-9_-]{6}\\.[A-Za-z0-9_-]{27,38}\\b",
    "positives": ["M{a:23}.{a:6}.{a:27}", "N{A:25}.{A:6}.{A:38}"],
    "negatives": ["M{a:10}.{a:6}.{a:27}", "X{a:23}.{a:6}.{a:27}", "a discord server"]
  },
  {
    "id": "figma_token",
    "label": "Figma personal access token",
    "severity": "critical",
    "pattern": "\\bfigd_[0-9A-Za-z_.-]{40,}\\b",
    "positives": ["figd_{a:20}.{b:20}", "figd_{A:24}.{B:24}"],
    "negatives": ["figd_short", "figx_{a:40}", "a figma file"]
  },
  {
    "id": "airtable_pat",
    "label": "Airtable personal access token",
    "severity": "critical",
    "pattern": "\\bpat[0-9A-Za-z]{14}\\.[0-9A-Za-z_-]{40,}\\b",
    "positives": ["pat{a:14}.{b:20}-{c:20}", "pat{A:14}.{0:20}_{1:20}"],
    "negatives": ["pat{a:14}.short", "patshort", "a patch file"]
  },
  {
    "id": "terraform_cloud_token",
    "label": "Terraform Cloud API token",
    "severity": "critical",
    "pattern": "\\b[A-Za-z0-9]{14}\\.atlasv1\\.[A-Za-z0-9_-]{60,}\\b",
    "positives": ["{a:14}.atlasv1.{b:60}", "{A:14}.atlasv1.{0:70}"],
    "negatives": ["{a:14}.atlasv2.{b:60}", "short.atlasv1.short", "a terraform plan"]
  },
  {
    "id": "dropbox_token",
    "label": "Dropbox access token",
    "severity": "critical",
    "pattern": "\\bsl\\.[A-Za-z0-9_-]{130,}\\b",
    "positives": ["sl.{a:130}", "sl.{A:140}"],
    "negatives": ["sl.short", "sl_{a:130}", "a slack message"]
  },
  {
    "id": "xai_key",
    "label": "xAI (Grok) API key",
    "severity": "critical",
    "pattern": "\\bxai-[A-Za-z0-9]{80}\\b",
    "positives": ["xai-{a:80}", "xai-{A:80}"],
    "negatives": ["xai-short", "xai-{a:79}", "an xai model"]
  },
  {
    "id": "flutterwave_secret",
    "label": "Flutterwave secret key",
    "severity": "critical",
    "pattern": "\\bFLWSECK[_-][0-9A-Za-z-]{20,}\\b",
    "positives": ["FLWSECK-{a:32}", "FLWSECK_TEST-{A:24}"],
    "negatives": ["FLWSECK-short", "FLWPUBK-{a:32}", "a flutterwave payment"]
  },
  {
    "id": "razorpay_key",
    "label": "Razorpay API key",
    "severity": "critical",
    "pattern": "\\brzp_(?:live|test)_[0-9A-Za-z]{14,}\\b",
    "positives": ["rzp_live_{a:14}", "rzp_test_{A:18}"],
    "negatives": ["rzp_live_short", "rzp_prod_{a:14}", "a razorpay order"]
  },
  {
    "id": "fireworks_key",
    "label": "Fireworks AI API key",
    "severity": "critical",
    "pattern": "\\bfw_[0-9A-Za-z]{24,}\\b",
    "positives": ["fw_{a:24}", "fw_{A:30}"],
    "negatives": ["fw_short", "fwd_{a:24}", "a firmware update"]
  },
  {
    "id": "atlassian_token",
    "label": "Atlassian API token",
    "severity": "critical",
    "pattern": "\\bATATT3x[A-Za-z0-9_=+/.-]{150,}\\b",
    "positives": ["ATATT3xFfGF0{a:150}", "ATATT3x{A:180}"],
    "negatives": ["ATATT3x_short", "ATATTshort", "an atlassian ticket"]
  },
  {
    "id": "tailscale_key",
    "label": "Tailscale auth key",
    "severity": "critical",
    "pattern": "\\btskey-(?:auth|api|client)-[A-Za-z0-9]{10,}-[A-Za-z0-9]{20,}\\b",
    "positives": ["tskey-auth-{a:12}-{b:40}", "tskey-api-{A:16}-{0:30}"],
    "negatives": ["tskey-auth-short", "tskey-xxxx-{a:12}-{b:40}", "a tailscale node"]
  }
]
