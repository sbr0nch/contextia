{
  "manifest_version": 3,
  "name": "Contextia",
  "version": "0.0.0",
  "description": "Catch secrets before they reach an AI chat. Local, on-device, no network.",
  "permissions": ["storage"],
  "host_permissions": ["https://chatgpt.com/*", "https://claude.ai/*"],
  "icons": { "16": "icons/icon-16.png", "48": "icons/icon-48.png", "128": "icons/icon-128.png" },
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://claude.ai/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Contextia",
    "default_popup": "popup.html",
    "default_icon": { "16": "icons/icon-16.png", "48": "icons/icon-48.png", "128": "icons/icon-128.png" }
  },
  "options_page": "options.html"
}
