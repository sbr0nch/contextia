{
  "name": "@contextia/extension",
  "version": "0.1.0",
  "private": true,
  "description": "Contextia MV3 browser extension. Consumes @contextia/engine.",
  "license": "MIT",
  "scripts": {
    "build": "node build.mjs",
    "dev": "node build.mjs --watch",
    "typecheck": "tsc -p tsconfig.json",
    "package": "node build.mjs && node pack.mjs",
    "test": "vitest run",
    "build:firefox": "node build.mjs --firefox",
    "package:firefox": "node build.mjs --firefox && node pack.mjs dist-firefox"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "esbuild": "^0.24.2",
    "happy-dom": "^15.11.7",
    "playwright": "^1.61.1",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@contextia/engine": "*"
  }
}
